  "sharedBlocks": {
    "about": "<div class=\"container\">\n        <h2 class=\"section-title\" id=\"about-table\">テーブルの見方</h2>\n        <table>\n            <thead>\n                <tr>\n                    <th>レベル</th>\n                    <th>説明</th>\n                    <th>分布</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr>\n                    <th>基礎</th>\n                    <td>正しいフォームを身につけ、1か月以上継続してトレーニングに励む。</td>\n                    <td>下位 5%</td>\n                </tr>\n                <tr>\n                    <th>初級</th>\n                    <td>6か月以上継続的にトレーニングに励む。</td>\n                    <td>上位 80%</td>\n                </tr>\n                <tr>\n                    <th>中級</th>\n                    <td>２年以上継続的にトレーニングに励む。</td>\n                    <td>上位 50%</td>\n                </tr>\n                <tr>\n                    <th>上級</th>\n                    <td>5年以上継続的にトレーニングに励む。</td>\n                    <td>上位 20%</td>\n                </tr>\n                <tr>\n                    <th>プロ</th>\n                    <td>5年以上当該メニューを専門にトレーニング。</td>\n                    <td>上位 5%</td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n",
