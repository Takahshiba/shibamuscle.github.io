    "about": "<div class=\"container\">\n        <h2 class=\"section-title\" id=\"about-table\">テーブルの見方</h2>\n        <table>\n            <thead>\n                <tr>\n                    <th>レベル</th>\n                    <th>説明</th>\n                    <th>分布</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr>\n                    <th>基礎</th>\n                    <td>正しいフォームを身につけ、1か月以上継続してトレーニングに励む。</td>\n                    <td>下位 5%</td>\n                </tr>\n                <tr>\n                    <th>初級</th>\n                    <td>6か月以上継続的にトレーニングに励む。</td>\n                    <td>上位 80%</td>\n                </tr>\n                <tr>\n                    <th>中級</th>\n                    <td>２年以上継続的にトレーニングに励む。</td>\n                    <td>上位 50%</td>\n                </tr>\n                <tr>\n                    <th>上級</th>\n                    <td>5年以上継続的にトレーニングに励む。</td>\n                    <td>上位 20%</td>\n                </tr>\n                <tr>\n                    <th>プロ</th>\n                    <td>5年以上当該メニューを専門にトレーニング。</td>\n                    <td>上位 5%</td>\n                </tr>\n            </tbody>\n        </table>\n    </div>\n",
    "calorie": "<div class=\"container\">\n        <h2 class=\"section-title\">10分あたりの消費カロリー</h2>\n    \n        <table class=\"calorie-burn-table\">\n            <thead>\n                <tr>\n                    <th>強度</th>\n                    <th>消費カロリー</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr>\n                    <th>低強度</th>\n                    <td>🔥 50-70 カロリー</td>\n                </tr>\n                <tr>\n                    <th>中強度</th>\n                    <td>🔥 70-100 カロリー</td>\n                </tr>\n                <tr>\n                    <th>高強度</th>\n                    <td>🔥 100-130 カロリー</td>\n                </tr>\n                <tr>\n                    <th>マックス</th>\n                    <td>🔥 130-160 カロリー</td>\n                </tr>                \n            </tbody>\n        </table>\n    \n        <div class=\"average-section-note\">\n            <p><strong>注：</strong>平均的な大人を想定した数値です。実際の消費カロリーは、体重、筋肉量、運動フォームなどの個人差によって異なる場合があります。</p>\n            \n            <p><strong>強度レベル：</strong></p>\n            <ul class=\"calorie-burn-intensity-list\">\n                <li><strong>低強度：</strong>ウォームアップセットやリカバリー運動</li>\n                <li><strong>中強度：</strong>標準的なワーキングセット</li>\n                <li><strong>高強度：</strong>高重量リフティングや高ボリューム</li>\n                <li><strong>マックス：</strong>限界挙上, レップ数やAMRAPセット</li>\n            </ul>\n        </div>\n    </div>\n"
